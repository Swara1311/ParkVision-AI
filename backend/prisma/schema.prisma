datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model ParkingLocation {
  id                String    @id @default(cuid())
  placeId           String?   @unique
  name              String
  address           String
  city              String
  latitude          Float
  longitude         Float
  totalSlots        Int
  fee               Float     @default(0)
  isEvCharging      Boolean   @default(false)
  isAccessible      Boolean   @default(false)
  openNow           Boolean   @default(true)
  openTime          String    @default("06:00")
  closeTime         String    @default("23:00")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  occupancySnapshots OccupancySnapshot[]
  searches           SearchLog[]

  @@index([city])
}

model OccupancySnapshot {
  id                String   @id @default(cuid())
  parkingLocationId String
  parkingLocation   ParkingLocation @relation(fields: [parkingLocationId], references: [id])
  availableSlots    Int
  occupiedSlots     Int
  recordedAt        DateTime @default(now())
  dayOfWeek         Int
  hourOfDay         Int

  @@index([parkingLocationId, recordedAt])
}

model SearchLog {
  id                String   @id @default(cuid())
  parkingLocationId String?
  parkingLocation   ParkingLocation? @relation(fields: [parkingLocationId], references: [id])
  city              String
  query             String?
  createdAt         DateTime @default(now())
}

model PredictionLog {
  id                  String   @id @default(cuid())
  parkingLocationId   String
  predictedAvailable  Int
  successProbability  Float
  estimatedSearchTime Int
  confidenceScore     Float
  createdAt           DateTime @default(now())
}